# LLM Providers
providers:
  openrouter:
    api_key: "sk-or-v1-..."
    base_url: "https://openrouter.ai/api/v1"

# Database
database:
  path: "osya.db"

# Server
server:
  host: "0.0.0.0"
  port: 8000

# Tool execution
workdir: "/tmp"
tool_timeout: 30

# Telegram (optional)
telegram:
  bot_token: ""
